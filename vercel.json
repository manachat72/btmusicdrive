{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/prisma/**", "server/node_modules/.prisma/**"]
      }
    },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "components.js", "use": "@vercel/static" },
    { "src": "checkout.js", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "products.json", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/src/index.ts" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" }
  ]
}
