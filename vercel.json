{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/prisma/**", "server/node_modules/.prisma/**"]
      }
    },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "components.js", "use": "@vercel/static" },
    { "src": "checkout.js", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "products.json", "use": "@vercel/static" },
    { "src": "categories.json", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/src/index.ts" },
    { "src": "/product/([^/]+)", "dest": "/product.html" },
    { "src": "/category/([^/]+)", "dest": "/category.html" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" }
  ]
}
